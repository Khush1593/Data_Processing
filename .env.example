# ======================================================================
# Stage 0 — Hybrid Data Pre-Processing Layer  (Clarum Insights)
# Copy this file to `.env` and fill in real values.
# ======================================================================

# ----- LLM provider selection -----
# Which provider writes the cleaning SQL. One of: groq | gemini
LLM_PROVIDER=groq

# Groq (OpenAI-compatible). Pick any model your account can access,
# e.g. openai/gpt-oss-120b, llama-3.3-70b-versatile, etc.
GROQ_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=

# Google Gemini (new unified SDK). e.g. gemini-2.0-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# LLM call tuning
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=60

# ----- Control-plane database (PostgreSQL) -----
# Stores sync_state, cold_start_progress, agent_memory (locked cleaning SQL).
CONTROL_DB_URI=postgresql+psycopg2://clarum:clarum@localhost:5433/clarum_control

# ----- Source database (the client's DB we read from) -----
# Used only by tests / examples. In production this is supplied per-request.
# SQLite example:   sqlite:////absolute/path/to/source.db
# Postgres example: postgresql+psycopg2://user:pass@host:5432/dbname
SOURCE_DB_URI=

# ----- Stage 0 tuning (from process.md §12) -----
PREPROCESSING_SAMPLE_SIZE=1000
PREPROCESSING_NAIVE_CHUNK_SIZE=10000
PREPROCESSING_CHUNK_SIZE=100000
PREPROCESSING_NULL_SPIKE_THRESHOLD=0.10
PREPROCESSING_RECONCILIATION_THRESHOLD=0.005
PREPROCESSING_ENABLED=true

# Where per-project clean DuckDB caches are written.
DUCKDB_CACHE_DIR=projects
